-- Silent Aim
local mt = getrawmetatable(game)
local old = mt.__namecall
setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    if silentAim and aimEnabled and currentTarget and currentTarget.Character then
        local part = currentTarget.Character:FindFirstChild(aimPart)
        if part and method == "FireServer" and self.Name:lower():find("bullet") or self.Name:lower():find("shoot") then
            args[1] = part.Position + (part.Velocity * predictionFactor)
        end
    end
    return old(self, unpack(args))
end)
setreadonly(mt, true)

