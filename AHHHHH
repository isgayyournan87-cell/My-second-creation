-- Key Listener
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if listeningForKey then
        listeningForKey(input.KeyCode)
        return
    end
    if input.KeyCode == targetKey then
        currentTarget = getClosestInFOV()
    elseif input.KeyCode == switchPartKey and currentTarget then
        aimPart = (aimPart == "Head") and "HumanoidRootPart" or "Head"
    end
end)

