-- Drawing ESP
local function createDrawingESP(plr)
    if plr == lp then return end
    local esp = {Box = Drawing.new("Square"), Name = Drawing.new("Text"), Distance = Drawing.new("Text")}
    esp.Box.Thickness = 2; esp.Box.Color = Color3.fromRGB(0,255,100); esp.Box.Transparency = 0.8; esp.Box.Filled = false
    esp.Name.Color = Color3.fromRGB(255,255,255); esp.Name.Size = 14; esp.Name.Center = true; esp.Name.Outline = true
    esp.Distance.Color = Color3.fromRGB(200,200,200); esp.Distance.Size = 13; esp.Distance.Center = true; esp.Distance.Outline = true
    drawings[plr] = esp
end

local function updateDrawingESP()
    for plr, esp in pairs(drawings) do
        local char = plr.Character
        if char and char:FindFirstChild("HumanoidRootPart") and espEnabled then
            local root = char.HumanoidRootPart
            local sPos, onScreen = camera:WorldToViewportPoint(root.Position)
            if onScreen then
                local dist = (camera.CFrame.Position - root.Position).Magnitude
                local head = char:FindFirstChild("Head")
                local top = head and camera:WorldToViewportPoint(head.Position + Vector3.new(0,1,0)) or sPos
                
                esp.Box.Size = Vector2.new(2400/dist, 3600/dist)
                esp.Box.Position = Vector2.new(sPos.X - esp.Box.Size.X/2, top.Y)
                esp.Box.Visible = true

                esp.Name.Text = plr.Name .. " [" .. aimPart .. "]"
                esp.Name.Position = Vector2.new(sPos.X, top.Y - 20)
                esp.Name.Visible = true

                esp.Distance.Text = string.format("%.0f", dist)
                esp.Distance.Position = Vector2.new(sPos.X, sPos.Y + esp.Box.Size.Y/2 + 5)
                esp.Distance.Visible = true
            else
                for _, v in pairs(esp) do v.Visible = false end
            end
        else
            for _, v in pairs(esp) do if v then v.Visible = false end end
        end
    end
end

local function isEnemy(plr)
    if not teamCheck then return true end
    if not lp.Team or not plr.Team then return true end
    return lp.Team \~= plr.Team
end

local function isVisible(char)
    if not char then return false end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {lp.Character}
    params.FilterType = Enum.RaycastFilterType.Exclude
    local res = Workspace:Raycast(camera.CFrame.Position, root.Position - camera.CFrame.Position, params)
    return not res or res.Instance:IsDescendantOf(char)
end

local function getClosestInFOV()
    local closest, minDist = nil, math.huge
    local mPos = Vector2.new(mouse.X, mouse.Y)
    for _, plr in Players:GetPlayers() do
        if plr \~= lp and isEnemy(plr) and plr.Character then
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local sPos, onScreen = camera:WorldToViewportPoint(root.Position)
                if onScreen then
                    local d = (Vector2.new(sPos.X, sPos.Y) - mPos).Magnitude
                    if d < fovRadius and d < minDist and isVisible(plr.Character) then
                        minDist = d
                        closest = plr
                    end
                end
            end
        end
    end
    return closest
end

local function mainLoop()
    if aimEnabled and currentTarget and currentTarget.Character then
        if not isVisible(currentTarget.Character) then
            currentTarget = getClosestInFOV()
        end
    else
        if aimEnabled then
            currentTarget = getClosestInFOV()
        end
    end

    updateDrawingESP()

    if triggerBot and aimEnabled and currentTarget then
        mouse1click()
    end
end

