-- Sliders
local function addSlider(txt, default, minV, maxV, callback)
    local frame = Instance.new("Frame", mainFrame)
    frame.Size = UDim2.new(1,-20,0,55)
    frame.Position = UDim2.new(0,10,0,y)
    frame.BackgroundTransparency = 1

    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1,0,0,20)
    label.Text = txt .. ": " .. string.format("%.2f", default)
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1

    local bar = Instance.new("Frame", frame)
    bar.Size = UDim2.new(1,0,0,8)
    bar.Position = UDim2.new(0,0,0,30)
    bar.BackgroundColor3 = Color3.fromRGB(50,50,50)
    Instance.new("UICorner", bar).CornerRadius = UDim.new(0,4)

    local inner = Instance.new("Frame", bar)
    inner.Size = UDim2.new((default-minV)/(maxV-minV),0,1,0)
    inner.BackgroundColor3 = Color3.fromRGB(0,170,255)
    Instance.new("UICorner", inner).CornerRadius = UDim.new(0,4)

    bar.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            local conn = UserInputService.InputChanged:Connect(function(m)
                if m.UserInputType == Enum.UserInputType.MouseMovement then
                    local x = math.clamp((m.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                    local val = minV + (maxV - minV) * x
                    callback(val)
                    inner.Size = UDim2.new(x,0,1,0)
                    label.Text = txt .. ": " .. string.format("%.2f", val)
                end
            end)
            UserInputService.InputEnded:Connect(function(e)
                if e.UserInputType == Enum.UserInputType.MouseButton1 then conn:Disconnect() end
            end)
        end
    end)
    y = y + 65
end

